@model CustomerCommanModel
<!--Grid Form-->
<div>
    <div class="flex flex-1  flex-col md:flex-row lg:flex-row mx-2">
        <div class="mb-2 border-solid border-gray-300 rounded border shadow-sm w-full">
            <div class="bg-gray-200 px-2 py-3 border-solid border-gray-200 border-b">
                Complaints
            </div>
            <div class="p-3">
                <form class="w-full" method="post" asp-controller="Vehicle" asp-action="SaveComplaints">
                    <div class="flex flex-wrap -mx-3 mb-6">
                        <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
                            <label class="block uppercase tracking-wide text-gray-700 text-xs font-light mb-1"
                                   for="grid-first-name">
                                Complaints:
                            </label>
                            <input type="hidden" asp-for="customerComplaints.ComplaintId" />
                            <input class="appearance-none block w-full bg-gray-200 text-grey-darker border border-gray-200 rounded py-3 px-4 leading-tight focus:outline-none focus:bg-white-500 focus:border-gray-600"
                                   id="grid-first-name" type="text" placeholder="Complaints" asp-for="customerComplaints.Complaints" required maxlength="100">
                        </div>
                        <div class="w-full md:w-1/2 px-3">
                            <label class="block uppercase tracking-wide text-gray-700 text-xs font-light mb-1"
                                   for="grid-last-name">
                                Price:
                            </label>
                            <input class="appearance-none block w-full bg-gray-200 text-grey-darker border border-gray-200 rounded py-3 px-4 leading-tight focus:outline-none focus:bg-white-500 focus:border-gray-600"
                                   id="grid-last-name" type="text" placeholder="Price" asp-for="customerComplaints.Price"  required>
                        </div>
                        <div class="w-full md:w-1/2 px-3">
                            <label class="block uppercase tracking-wide text-gray-700 text-xs font-light mb-1"
                                   for="grid-last-name">
                                VehicleTypeId:
                            </label>
                            <input class="appearance-none block w-full bg-gray-200 text-grey-darker border border-gray-200 rounded py-3 px-4 leading-tight focus:outline-none focus:bg-white-500 focus:border-gray-600"
                                   id="grid-last-name" type="number" placeholder="Vehicle TypeId" asp-for="customerComplaints.VehicleTypeId"  required>
                        </div>
                        <div class="w-full md:w-1/2 px-3">
                            <label class="block uppercase tracking-wide text-gray-700 text-xs font-light mb-1"
                                   for="grid-last-name">
                                <br />
                            </label>
                            <button class="bg-green-500 hover:bg-green-800 text-white font-bold py-3 px-4 rounded" type="submit" />Save
                            <button class="bg-blue-500 hover:bg-blue-800 text-white font-bold py-3 px-4 rounded" type="reset" />Cancel
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
<br />
<!--/Grid Form-->