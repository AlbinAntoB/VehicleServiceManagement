@model CustomerCommanModel
<!-- Main CSS-->
<link href="css/main.css" rel="stylesheet" media="all">
<!--Grid Form-->
<div class="flex flex-1  flex-col md:flex-row lg:flex-row mx-2 mb-5">
    <div class="mb-2 border-solid border-gray-300 rounded border shadow-sm w-full">
        <div class="bg-gray-200 px-2 py-3 border-solid border-gray-200 border-b">
            Comman Complaints
        </div>
            <input class="btn btn--radius-2 btn--red" type="button" onclick="@("window.location.href='" + @Url.Action("Complaintsform", "Vehicle") + "'")" value="Add New Complaint" />
            <div class="table-responsive-md">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="border w-1/6 px-4 py-2">Action</th>
                            <th class="border w-1/6 px-4 py-2">Complaints</th>
                            <th class="border w-1/6 px-4 py-2">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (CustomerComplaints complaints in Model.customerComplaintsList)
                        {
                            <tr>
                                <td class="border px-4 py-2">
                                    <a class="bg-teal-300 cursor-pointer rounded p-1 mx-1 text-white" asp-route-ComplaintId="@complaints.ComplaintId" asp-controller="Vehicle" asp-action="EditComplaint">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a class="bg-teal-300 cursor-pointer rounded p-1 mx-1 text-red-500" onclick="Delete(@complaints.ComplaintId)">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                                <td>@complaints.Complaints</td>
                                <td>@complaints.Price</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
<!--/Grid Form-->
<script>
    function Delete(ComplaintId) {
        debugger;
        var x = confirm("Are you sure do you want to delete?");
        if (x)
            window.location.href = "/Vehicle/DeleteComplaint?ComplaintId=" + ComplaintId;
        else
            return false;
    }
</script>